# Environment Variables for Vercel Deployment
# Copy this file to .env for local development
# Add these variables to Vercel Dashboard > Settings > Environment Variables

# MongoDB Atlas Connection String (Required for Vercel)
# Get this from: https://cloud.mongodb.com/
# Format: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net

# Express Session Secret (Required)
# Generate a random string for production
EXPRESS_SESSION_SECRET=your-super-secret-random-string-here

# Node Environment (Optional)
NODE_ENV=production
